#!/usr/bin/env php
<?php declare(strict_types=1);

namespace Rxn\Framework\Bench;

/**
 * Microbenchmarks for the framework's building blocks. Not a
 * full-stack HTTP benchmark — see `bench/compare/` for that.
 *
 * Each case is run for ~250ms with a ~50ms warmup. Output is a
 * table of ops/sec and ns/op so apples-to-apples comparisons
 * against other minimalist frameworks can happen at the primitive
 * level.
 *
 *   php bin/bench              # run everything
 *   php bin/bench router       # filter by substring
 *   php bin/bench --json       # JSON array, one object per case
 *   php bin/bench --json router
 *
 * Storage / query-builder cases live in the rxn-orm repo's own
 * bench harness — this file only covers framework-resident
 * primitives (Router, Pipeline, Container, Binder, Validator,
 * PsrAdapter).
 */

require_once __DIR__ . '/../vendor/autoload.php';

use Rxn\Framework\Container;
use Nyholm\Psr7\Response as Psr7Response;
use Nyholm\Psr7\ServerRequest;
use Psr\Http\Message\ResponseInterface;
use Psr\Http\Message\ServerRequestInterface;
use Psr\Http\Server\MiddlewareInterface;
use Psr\Http\Server\RequestHandlerInterface;
use Rxn\Framework\Http\Attribute\InSet;
use Rxn\Framework\Http\Attribute\Length;
use Rxn\Framework\Http\Attribute\Min;
use Rxn\Framework\Http\Attribute\Required;
use Rxn\Framework\Http\Binding\Binder;
use Rxn\Framework\Http\Binding\RequestDto;
use Rxn\Framework\Http\Pipeline;
use Rxn\Framework\Http\PsrAdapter;
use Rxn\Framework\Http\Router;
use Rxn\Framework\Utility\Validator;

// Argv parsing: positional substring filter + optional --json flag.
// Stays minimal; the driver in bench/ab.php is the consumer of --json.
$asJson = false;
$filter = null;
foreach (array_slice($argv, 1) as $arg) {
    if ($arg === '--json') { $asJson = true; continue; }
    if (str_starts_with($arg, '--')) { continue; } // ignore unknown flags
    if ($filter === null) { $filter = $arg; }
}

$cases = [];

// Router: registered matches
$router = new Router();
$router->get('/', 'home');
$router->get('/products', 'list');
$router->get('/products/{id}', 'show');
$router->get('/users/{uid}/orders/{oid}', 'userOrder');
$router->post('/products', 'create');

$cases['router.match.static'] = function () use ($router) {
    return $router->match('GET', '/products');
};
$cases['router.match.single_param'] = function () use ($router) {
    return $router->match('GET', '/products/42');
};
$cases['router.match.multi_param'] = function () use ($router) {
    return $router->match('GET', '/users/7/orders/42');
};
$cases['router.match.miss'] = function () use ($router) {
    return $router->match('GET', '/no/such/route');
};

// "Realistic" many-route table: 5 routes per HTTP verb across
// GET/POST/PUT/DELETE = 20 routes total. The cases below probe
// the verb-bucket optimization opportunity — a request whose verb
// only matches a small slice of the table shouldn't pay to walk
// all 20 routes on every miss.
$big = new Router();
foreach (['GET', 'POST', 'PUT', 'DELETE'] as $verb) {
    $lower = strtolower($verb);
    for ($i = 0; $i < 5; $i++) {
        $big->add($verb, "/$lower/path/$i", "h-$verb-$i");
    }
}

$cases['router.match.many.first_verb_hit'] = function () use ($big) {
    // GET /get/path/0 — best case, hits the very first registered route
    return $big->match('GET', '/get/path/0');
};
$cases['router.match.many.last_verb_hit'] = function () use ($big) {
    // DELETE /delete/path/4 — last verb, last route in its bucket;
    // a verb-bucketed router only walks 5, a linear router walks 20
    return $big->match('DELETE', '/delete/path/4');
};
$cases['router.match.many.miss'] = function () use ($big) {
    // Walks the entire table on a linear matcher; with verb buckets
    // it only walks the routes for GET (5).
    return $big->match('GET', '/no/such/route');
};

// Placeholder-bucket-heavy table: 10 placeholder routes per verb,
// every route requires a real preg_match (no static-hashmap
// fast-path). This is the case that combined-regex chunking
// (FastRoute-style) would optimise — each match currently walks
// preg_match() once per route in the verb bucket.
$bucket = new Router();
foreach (['GET', 'POST', 'PUT', 'DELETE'] as $verb) {
    $lower = strtolower($verb);
    for ($i = 0; $i < 10; $i++) {
        // Each route uses {id:int} so they're all real-regex routes.
        $bucket->add($verb, "/$lower/resource$i/{id:int}", "h-$verb-$i");
    }
}

$cases['router.match.bucket.first_hit'] = function () use ($bucket) {
    // GET /get/resource0/42 — best case in a placeholder bucket
    return $bucket->match('GET', '/get/resource0/42');
};
$cases['router.match.bucket.last_hit'] = function () use ($bucket) {
    // DELETE /delete/resource9/42 — 10th route in the DELETE bucket;
    // current impl walks preg_match 10 times before hitting.
    return $bucket->match('DELETE', '/delete/resource9/42');
};
$cases['router.match.bucket.miss'] = function () use ($bucket) {
    // No match — current impl walks every route in the GET bucket.
    return $bucket->match('GET', '/get/resource99/42');
};

// Pipeline: 3-layer pass-through (PSR-15)
$noop = new class implements MiddlewareInterface {
    public function process(ServerRequestInterface $request, RequestHandlerInterface $handler): ResponseInterface
    {
        return $handler->handle($request);
    }
};
$pipeline = (new Pipeline())->add($noop)->add($noop)->add($noop);
$psrRequest  = new ServerRequest('GET', 'http://test.local/');
$psrResponse = new Psr7Response(200);
$terminal = new class($psrResponse) implements RequestHandlerInterface {
    public function __construct(private ResponseInterface $r) {}
    public function handle(ServerRequestInterface $request): ResponseInterface { return $this->r; }
};

$cases['pipeline.3layer'] = function () use ($pipeline, $psrRequest, $terminal) {
    return $pipeline->run($psrRequest, $terminal);
};

// Validator: realistic payload + rule set
$payload = [
    'email' => 'u@example.com',
    'age'   => 42,
    'role'  => 'member',
    'slug'  => 'abc-123',
];
$rules = [
    'email' => ['required', 'email'],
    'age'   => ['required', 'int', 'min:18', 'max:120'],
    'role'  => ['in:admin,member,guest'],
    'slug'  => ['regex:/^[a-z0-9-]+$/'],
];
$cases['validator.check.clean'] = function () use ($payload, $rules) {
    return Validator::check($payload, $rules);
};
$compiledCheck = Validator::compile($rules);
$cases['validator.check.compiled'] = function () use ($payload, $compiledCheck) {
    return $compiledCheck($payload);
};

// Container: autowire a simple chain A -> B -> C
class BenchC {}
class BenchB { public function __construct(public BenchC $c) {} }
class BenchA { public function __construct(public BenchB $b) {} }

$cases['container.get.depth_3'] = function () {
    $c = new Container();
    return $c->get(BenchA::class);
};

// PSR-7: build a ServerRequest from a fixed set of globals
$originalServer = $_SERVER;
$_SERVER = array_merge($_SERVER, [
    'REQUEST_METHOD'  => 'GET',
    'REQUEST_URI'     => '/products/42',
    'QUERY_STRING'    => '',
    'HTTP_HOST'       => 'example.test',
    'SERVER_PROTOCOL' => 'HTTP/1.1',
]);
$cases['psr7.from_globals'] = function () {
    return PsrAdapter::serverRequestFromGlobals();
};
// leave $_SERVER modified for the run; restore at end.

// Binder: realistic 5-field DTO with mixed validation attributes
class BenchProductBindDto implements RequestDto
{
    #[Required]
    #[Length(min: 1, max: 100)]
    public string $name;

    #[Required]
    #[Min(0)]
    public int $price;

    public bool $active = true;

    #[Length(max: 500)]
    public ?string $description = null;

    #[InSet(['draft', 'published', 'archived'])]
    public string $status = 'draft';
}
$bindBag = [
    'name'        => 'Widget',
    'price'       => '9',
    'active'      => 'true',
    'description' => 'A nice widget',
    'status'      => 'published',
];
$cases['binder.bind.runtime'] = function () use ($bindBag) {
    return Binder::bind(BenchProductBindDto::class, $bindBag);
};
$compiledBinder = Binder::compileFor(BenchProductBindDto::class);
$cases['binder.bind.compiled'] = function () use ($bindBag, $compiledBinder) {
    return $compiledBinder($bindBag);
};

function run_case(callable $fn, float $warmup_s = 0.05, float $run_s = 0.25): array
{
    // warmup
    $warmEnd = microtime(true) + $warmup_s;
    while (microtime(true) < $warmEnd) {
        $fn();
    }
    // timed run
    $iterations = 0;
    $start      = microtime(true);
    $deadline   = $start + $run_s;
    while (microtime(true) < $deadline) {
        $fn();
        $iterations++;
    }
    $elapsed = microtime(true) - $start;
    return [
        'iter'    => $iterations,
        'elapsed' => $elapsed,
        'ops_s'   => $iterations / $elapsed,
        'ns_op'   => ($elapsed * 1e9) / max(1, $iterations),
    ];
}

if ($asJson) {
    $rows = [];
    foreach ($cases as $name => $fn) {
        if ($filter !== null && !str_contains($name, $filter)) {
            continue;
        }
        $r = run_case($fn);
        $rows[] = [
            'case'   => $name,
            'iter'   => $r['iter'],
            'ops_s'  => $r['ops_s'],
            'ns_op'  => $r['ns_op'],
        ];
    }
    fwrite(STDOUT, json_encode($rows, JSON_PRETTY_PRINT) . "\n");
} else {
    printf("%-30s %14s %14s\n", 'case', 'ops/sec', 'ns/op');
    printf("%-30s %14s %14s\n", str_repeat('-', 30), str_repeat('-', 14), str_repeat('-', 14));

    foreach ($cases as $name => $fn) {
        if ($filter !== null && !str_contains($name, $filter)) {
            continue;
        }
        $r = run_case($fn);
        printf(
            "%-30s %14s %14s\n",
            $name,
            number_format($r['ops_s'], 0),
            number_format($r['ns_op'], 0)
        );
    }
}

$_SERVER = $originalServer;
