#!/usr/bin/env php
<?php declare(strict_types=1);

namespace Rxn\Framework\Bench;

/**
 * Microbenchmarks for the framework's building blocks. Not a
 * full-stack HTTP benchmark — App::run()'s startup flow has
 * open bugs that make end-to-end numbers meaningless today.
 *
 * Each case is run for ~250ms with a ~50ms warmup. Output is a
 * table of ops/sec and ns/op so apples-to-apples comparisons
 * against other minimalist frameworks can happen at the primitive
 * level.
 *
 *   php bin/bench              # run everything
 *   php bin/bench router       # filter by substring
 *   php bin/bench --json       # JSON array, one object per case
 *   php bin/bench --json router
 */

require_once __DIR__ . '/../vendor/autoload.php';

use Rxn\Framework\Container;
use Rxn\Framework\Http\Middleware;
use Rxn\Framework\Http\Pipeline;
use Rxn\Framework\Http\PsrAdapter;
use Rxn\Framework\Http\Request;
use Rxn\Framework\Http\Response;
use Rxn\Framework\Http\Router;
use Rxn\Framework\Model\ActiveRecord;
use Rxn\Framework\Utility\Validator;
use Rxn\Orm\Builder\Delete;
use Rxn\Orm\Builder\Insert;
use Rxn\Orm\Builder\Query;
use Rxn\Orm\Builder\Raw;
use Rxn\Orm\Builder\Update;

// Argv parsing: positional substring filter + optional --json flag.
// Stays minimal; the driver in bench/ab.php is the consumer of --json.
$asJson = false;
$filter = null;
foreach (array_slice($argv, 1) as $arg) {
    if ($arg === '--json') { $asJson = true; continue; }
    if (str_starts_with($arg, '--')) { continue; } // ignore unknown flags
    if ($filter === null) { $filter = $arg; }
}

$cases = [];

// Router: registered matches
$router = new Router();
$router->get('/', 'home');
$router->get('/products', 'list');
$router->get('/products/{id}', 'show');
$router->get('/users/{uid}/orders/{oid}', 'userOrder');
$router->post('/products', 'create');

$cases['router.match.static'] = function () use ($router) {
    return $router->match('GET', '/products');
};
$cases['router.match.single_param'] = function () use ($router) {
    return $router->match('GET', '/products/42');
};
$cases['router.match.multi_param'] = function () use ($router) {
    return $router->match('GET', '/users/7/orders/42');
};
$cases['router.match.miss'] = function () use ($router) {
    return $router->match('GET', '/no/such/route');
};

// "Realistic" many-route table: 5 routes per HTTP verb across
// GET/POST/PUT/DELETE = 20 routes total. The cases below probe
// the verb-bucket optimization opportunity — a request whose verb
// only matches a small slice of the table shouldn't pay to walk
// all 20 routes on every miss.
$big = new Router();
foreach (['GET', 'POST', 'PUT', 'DELETE'] as $verb) {
    $lower = strtolower($verb);
    for ($i = 0; $i < 5; $i++) {
        $big->add($verb, "/$lower/path/$i", "h-$verb-$i");
    }
}

$cases['router.match.many.first_verb_hit'] = function () use ($big) {
    // GET /get/path/0 — best case, hits the very first registered route
    return $big->match('GET', '/get/path/0');
};
$cases['router.match.many.last_verb_hit'] = function () use ($big) {
    // DELETE /delete/path/4 — last verb, last route in its bucket;
    // a verb-bucketed router only walks 5, a linear router walks 20
    return $big->match('DELETE', '/delete/path/4');
};
$cases['router.match.many.miss'] = function () use ($big) {
    // Walks the entire table on a linear matcher; with verb buckets
    // it only walks the routes for GET (5).
    return $big->match('GET', '/no/such/route');
};

// Pipeline: 3-layer pass-through
$noop = new class implements Middleware {
    public function handle(Request $request, callable $next): Response
    {
        return $next($request);
    }
};
$pipeline = (new Pipeline())->add($noop)->add($noop)->add($noop);
$request  = (new \ReflectionClass(Request::class))->newInstanceWithoutConstructor();
$response = (new \ReflectionClass(Response::class))->newInstanceWithoutConstructor();
$terminal = static fn () => $response;

$cases['pipeline.3layer'] = function () use ($pipeline, $request, $terminal) {
    return $pipeline->handle($request, $terminal);
};

// Validator: realistic payload + rule set
$payload = [
    'email' => 'u@example.com',
    'age'   => 42,
    'role'  => 'member',
    'slug'  => 'abc-123',
];
$rules = [
    'email' => ['required', 'email'],
    'age'   => ['required', 'int', 'min:18', 'max:120'],
    'role'  => ['in:admin,member,guest'],
    'slug'  => ['regex:/^[a-z0-9-]+$/'],
];
$cases['validator.check.clean'] = function () use ($payload, $rules) {
    return Validator::check($payload, $rules);
};

// Container: autowire a simple chain A -> B -> C
class BenchC {}
class BenchB { public function __construct(public BenchC $c) {} }
class BenchA { public function __construct(public BenchB $b) {} }

$cases['container.get.depth_3'] = function () {
    $c = new Container();
    return $c->get(BenchA::class);
};

// Query builder: realistic compound SELECT
$cases['builder.select.compound'] = function () {
    (new Query())
        ->select(['u.id', 'u.email'])
        ->from('users', 'u')
        ->leftJoin('orders', 'o.user_id', '=', 'u.id', 'o')
        ->where('u.active', '=', 1)
        ->andWhereIn('u.role', ['admin', 'owner'])
        ->andWhereIsNull('u.deleted_at')
        ->groupBy('u.id')
        ->orderBy('u.id', 'DESC')
        ->limit(50)
        ->toSql();
};

$cases['builder.select.subquery'] = function () {
    $sub = (new Query())
        ->select([Raw::of('COUNT(*)')])
        ->from('orders')
        ->where('user_id', '=', Raw::of('u.id'));
    (new Query())
        ->select(['u.id'])
        ->selectSubquery($sub, 'order_count')
        ->from('users', 'u')
        ->where('u.active', '=', 1)
        ->toSql();
};

$cases['builder.insert.multirow'] = function () {
    (new Insert())
        ->into('users')
        ->rows([
            ['email' => 'a@example.com', 'role' => 'admin'],
            ['email' => 'b@example.com', 'role' => 'member'],
            ['email' => 'c@example.com', 'role' => 'member'],
        ])
        ->toSql();
};

$cases['builder.update.simple'] = function () {
    (new Update())
        ->table('users')
        ->set(['role' => 'admin', 'updated_at' => Raw::of('NOW()')])
        ->where('id', '=', 42)
        ->toSql();
};

$cases['builder.delete.simple'] = function () {
    (new Delete())
        ->from('users')
        ->where('deleted_at', '<', '2025-01-01')
        ->toSql();
};

// ActiveRecord hydrate on a batch of rows
class BenchAR extends ActiveRecord
{
    public const TABLE = 'bench';
}
$rows100 = array_map(
    fn (int $i) => ['id' => $i, 'email' => "u$i@example.com", 'role' => 'member'],
    range(1, 100)
);
$cases['active_record.hydrate_100'] = function () use ($rows100) {
    ActiveRecord::hydrate($rows100, BenchAR::class);
};

// PSR-7: build a ServerRequest from a fixed set of globals
$originalServer = $_SERVER;
$_SERVER = array_merge($_SERVER, [
    'REQUEST_METHOD'  => 'GET',
    'REQUEST_URI'     => '/products/42',
    'QUERY_STRING'    => '',
    'HTTP_HOST'       => 'example.test',
    'SERVER_PROTOCOL' => 'HTTP/1.1',
]);
$cases['psr7.from_globals'] = function () {
    return PsrAdapter::serverRequestFromGlobals();
};
// leave $_SERVER modified for the run; restore at end.

// CompiledJson: encode 100 typed DTOs
class BenchProductDto
{
    public int    $id;
    public string $name;
    public float  $price;
    public bool   $active;
    public ?string $note;

    public function __construct(int $id, string $name, float $price, bool $active, ?string $note)
    {
        $this->id     = $id;
        $this->name   = $name;
        $this->price  = $price;
        $this->active = $active;
        $this->note   = $note;
    }
}
$dtos100 = array_map(
    static fn (int $i) => new BenchProductDto(
        $i,
        "Product $i \"alt\"",
        9.99 + $i,
        $i % 2 === 0,
        $i % 3 === 0 ? null : "Note for $i",
    ),
    range(1, 100),
);
// Warm the encoder cache so the first iteration doesn't pay the
// reflection / eval cost (that's amortised over the process
// lifetime in production; the bench measures steady-state per-call).
\Rxn\Framework\Http\CompiledJson::for(BenchProductDto::class);

$singleDto = $dtos100[0];
$cases['json.encode_dto.single.baseline'] = function () use ($singleDto) {
    return json_encode($singleDto, JSON_UNESCAPED_SLASHES);
};
$cases['json.encode_dto.single.compiled'] = function () use ($singleDto) {
    $encode = \Rxn\Framework\Http\CompiledJson::for(BenchProductDto::class);
    return $encode($singleDto);
};

$cases['json.encode_dto.list.baseline'] = function () use ($dtos100) {
    return json_encode($dtos100, JSON_UNESCAPED_SLASHES);
};
$cases['json.encode_dto.list.compiled'] = function () use ($dtos100) {
    $encode = \Rxn\Framework\Http\CompiledJson::for(BenchProductDto::class);
    $parts  = [];
    foreach ($dtos100 as $dto) {
        $parts[] = $encode($dto);
    }
    return '[' . implode(',', $parts) . ']';
};
// Batch-compiled encoder: one eval'd closure that iterates the whole
// array, so the 100 invocations of the per-DTO closure collapse into
// one call.
$encodeList = \Rxn\Framework\Http\CompiledJson::forList(BenchProductDto::class);
$cases['json.encode_dto.list.compiled_batch'] = function () use ($dtos100, $encodeList) {
    return $encodeList($dtos100);
};

function run_case(callable $fn, float $warmup_s = 0.05, float $run_s = 0.25): array
{
    // warmup
    $warmEnd = microtime(true) + $warmup_s;
    while (microtime(true) < $warmEnd) {
        $fn();
    }
    // timed run
    $iterations = 0;
    $start      = microtime(true);
    $deadline   = $start + $run_s;
    while (microtime(true) < $deadline) {
        $fn();
        $iterations++;
    }
    $elapsed = microtime(true) - $start;
    return [
        'iter'    => $iterations,
        'elapsed' => $elapsed,
        'ops_s'   => $iterations / $elapsed,
        'ns_op'   => ($elapsed * 1e9) / max(1, $iterations),
    ];
}

if ($asJson) {
    $rows = [];
    foreach ($cases as $name => $fn) {
        if ($filter !== null && !str_contains($name, $filter)) {
            continue;
        }
        $r = run_case($fn);
        $rows[] = [
            'case'   => $name,
            'iter'   => $r['iter'],
            'ops_s'  => $r['ops_s'],
            'ns_op'  => $r['ns_op'],
        ];
    }
    fwrite(STDOUT, json_encode($rows, JSON_PRETTY_PRINT) . "\n");
} else {
    printf("%-30s %14s %14s\n", 'case', 'ops/sec', 'ns/op');
    printf("%-30s %14s %14s\n", str_repeat('-', 30), str_repeat('-', 14), str_repeat('-', 14));

    foreach ($cases as $name => $fn) {
        if ($filter !== null && !str_contains($name, $filter)) {
            continue;
        }
        $r = run_case($fn);
        printf(
            "%-30s %14s %14s\n",
            $name,
            number_format($r['ops_s'], 0),
            number_format($r['ns_op'], 0)
        );
    }
}

$_SERVER = $originalServer;
